{
  "name": "forge-studio",
  "version": "3.0.0",
  "private": true,
  "description": "Self-hosted AI Lab Control Center — unified proxy for LLM providers",
  "author": "Jahanzaib Ali",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm dev:server",
    "dev:server": "tsx watch --tsconfig tsconfig.json server/_core/index.ts",
    "dev:client": "vite",
    "dev:landing": "next dev -p 3000",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "vite build",
    "build:server": "node -e \"require('esbuild').buildSync({entryPoints:['server/_core/index.ts'],bundle:true,platform:'node',target:'node22',outfile:'dist/index.js',external:['sharp','@img/sharp-linux-x64']})\"",
    "build:landing": "next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "node dist/index.js",
    "start:landing": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/seed.ts",
    "db:generate": "prisma generate",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
