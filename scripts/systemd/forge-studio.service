[Unit]
Description=Forge Studio v3.0 — AI Lab Control Center
After=network.target forge-postgres.service forge-redis.service
Requires=forge-postgres.service forge-redis.service

[Service]
Type=simple
User=jahanzaib
Group=jahanzaib
WorkingDirectory=/home/jahanzaib/forge-studio
ExecStart=/home/jahanzaib/.nvm/versions/node/v23.5.0/bin/npx tsx server/_core/index.ts
Restart=always
RestartSec=5
Environment=NODE_ENV=development
Environment=PORT=5051
Environment=DATABASE_URL=postgresql://litellm_user:litellm_password_123@localhost:5434/forge_studio
Environment=REDIS_URL=redis://localhost:6379/1
Environment=JWT_SECRET=forge-studio-dev-secret-key-change-in-production
Environment=ALLOWED_ORIGINS=http://localhost:5051,http://localhost:3000,http://localhost:8080
Environment=PATH=/home/jahanzaib/.nvm/versions/node/v23.5.0/bin:/usr/local/bin:/usr/bin:/bin

StandardOutput=journal
StandardError=journal
SyslogIdentifier=forge-studio

[Install]
WantedBy=multi-user.target
