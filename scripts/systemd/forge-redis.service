[Unit]
Description=Forge Studio — Redis (Docker Container)
After=docker.service
Requires=docker.service

[Service]
Type=simple
ExecStart=/usr/bin/docker start -a futureagi-redis-1
ExecStop=/usr/bin/docker stop futureagi-redis-1
Restart=always
RestartSec=10
TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
